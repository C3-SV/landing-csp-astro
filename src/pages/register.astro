---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageMetadata } from "../lib/site";

export const prerender = true;
---

<BaseLayout
    title={pageMetadata.register.title}
    description={pageMetadata.register.description}
    canonical={pageMetadata.register.canonical}
>
    <!-- ─── HERO ─────────────────────────────────────────────── -->
    <section class="rg-section rg-hero">
        <div class="rg-container rg-hero-grid">
            <div>
                <h1 class="rg-hero-title">¿Listos para<br />competir?</h1>
                <p class="rg-hero-sub">
                    Inscribirse es gratis y el proceso toma menos de 5 minutos.
                    Solo necesitas tu equipo y tus carnets estudiantiles
                </p>
            </div>

            <div style="position:relative;">
                <div
                    style="border-radius:1rem;border:1px solid #e5e7eb;overflow:hidden;box-shadow:0 12px 40px rgba(58,46,137,.14);"
                >
                    <div
                        style="background:#f3f4f6;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem;"
                    >
                        <div style="display:flex;gap:6px;">
                            <span
                                style="width:12px;height:12px;border-radius:50%;background:#f87171;display:block;"
                            ></span>
                            <span
                                style="width:12px;height:12px;border-radius:50%;background:#fbbf24;display:block;"
                            ></span>
                            <span
                                style="width:12px;height:12px;border-radius:50%;background:#4ade80;display:block;"
                            ></span>
                        </div>
                        <span
                            style="flex:1;background:#fff;border-radius:4px;padding:4px 12px;font-size:.7rem;color:#9ca3af;text-align:center;"
                            >app.omegaup.co</span
                        >
                        <div
                            style="display:flex;gap:8px;font-size:.7rem;color:#9ca3af;"
                        >
                            <span>&lt;</span><span>&gt;</span>
                        </div>
                    </div>
                    <div
                        style="aspect-ratio:16/9;position:relative;overflow:hidden;"
                    >
                        <img
                            src="/registerPhotos/RegisterPic6.webp"
                            alt="Copa Salvadoreña de Programación"
                            style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
                        />
                        <div
                            style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;"
                        >
                            <button
                                aria-label="Reproducir recurso introductorio de la Copa"
                                style="width:56px;height:56px;border-radius:50%;background:rgba(255,255,255,.85);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(0,0,0,.15);"
                            >
                                <svg
                                    width="24"
                                    height="24"
                                    fill="#3A2E89"
                                    viewBox="0 0 24 24"
                                    style="margin-left:3px;"
                                >
                                    <path d="M8 5v14l11-7z"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
                <span class="rg-deco" style="right:-1rem;top:40%;">+</span>
                <span
                    class="rg-deco"
                    style="right:-1.5rem;top:65%;opacity:.2;font-size:1rem;"
                    >+</span
                >
            </div>
        </div>
        <span
            class="rg-deco"
            style="bottom:2rem;left:1rem;opacity:.2;font-size:1rem;">+</span
        >
    </section>

    <!-- ─── PROCESO DE INSCRIPCIÓN ────────────────────────────── -->
    <section class="rg-section">
        <div class="rg-container">
            <div class="rg-proceso-grid">
                <!-- Left: photos (hidden on mobile) -->
                <div class="rg-photos">
                    <span class="rg-deco" style="left:-1.25rem;top:42%;">+</span
                    >
                    <span
                        class="rg-deco"
                        style="left:-1.25rem;top:56%;opacity:.22;font-size:.9rem;"
                        >+</span
                    >
                    <span
                        class="rg-deco"
                        style="left:-1.25rem;top:70%;opacity:.12;font-size:.8rem;"
                        >+</span
                    >

                    <div
                        style="position:absolute;left:-25px;top:30px;width:210px;height:295px;border-radius:.75rem;overflow:hidden;box-shadow:0 4px 20px rgba(58,46,137,.08);"
                    >
                        <img
                            src="/registerPhotos/RegisterPic5.webp"
                            alt="Estudiante participante durante una actividad de programación competitiva"
                            style="width:100%;height:100%;object-fit:cover;"
                        />
                    </div>
                    <div
                        style="position:absolute;left:145px;bottom:25px;width:235px;height:335px;border-radius:.75rem;overflow:hidden;box-shadow:0 12px 40px rgba(58,46,137,.18);"
                    >
                        <img
                            src="/registerPhotos/RegisterPic4.webp"
                            alt="Participante trabajando durante la Copa Salvadoreña de Programación"
                            style="width:100%;height:100%;object-fit:cover;"
                        />
                    </div>

                    <div
                        style="position:absolute;left:322px;top:58px;width:115px;height:115px;border-radius:50%;background:#0BAA9F;display:flex;align-items:center;justify-content:center;z-index:10;"
                    >
                        <span
                            style="color:#fff;font-size:.9rem;font-weight:600;text-align:center;line-height:1.4;font-family:'Poppins',sans-serif;"
                            >Inscripción<br />gratuita</span
                        >
                    </div>
                </div>

                <!-- Right: steps -->
                <div>
                    <!-- badge visible only on mobile -->
                    <div class="rg-badge-mobile">
                        <div
                            style="width:90px;height:90px;border-radius:50%;background:#0BAA9F;display:flex;align-items:center;justify-content:center;"
                        >
                            <span
                                style="color:#fff;font-size:.85rem;font-weight:600;text-align:center;line-height:1.4;font-family:'Poppins',sans-serif;"
                                >Inscripción<br />gratuita</span
                            >
                        </div>
                    </div>

                    <h2
                        style="font-family:'Poppins',sans-serif;font-size:1.875rem;font-weight:700;color:#3A2E89;margin:0 0 1.5rem;padding-top:.5rem;"
                    >
                        Proceso de inscripción
                    </h2>

                    <ol class="rg-steps">
                        {
                            [
                                {
                                    n: 1,
                                    t: "Forma tu equipo",
                                    d: "3 estudiantes de la misma institución",
                                },
                                {
                                    n: 2,
                                    t: "Llena el formulario",
                                    d: "Solamente un estudiante registra al equipo",
                                },
                                {
                                    n: 3,
                                    t: "Adjunta los carnets",
                                    d: "Foto o escaneo del carnet de todos los integrantes",
                                },
                                {
                                    n: 4,
                                    t: "Espera confirmación",
                                    d: "Recibirán aviso de participación",
                                },
                            ].map((s) => (
                                <li class="rg-step">
                                    <span class="rg-step-number">
                                        {s.n}
                                    </span>
                                    <div class="rg-step-copy">
                                        <p class="rg-step-title">
                                            {s.t}
                                        </p>
                                        <p class="rg-step-desc">
                                            {s.d}
                                        </p>
                                    </div>
                                </li>
                            ))
                        }
                    </ol>
                </div>
            </div>

            <div style="text-align:center;margin-top:2.5rem;">
                <a
                    href="https://www.youtube.com/@C3_ElSalvador"
                    target="_blank"
                    rel="noopener noreferrer"
                    style="display:inline-flex;align-items:center;gap:.5rem;border:1.5px solid #3A2E89;border-radius:.5rem;padding:.625rem 1.5rem;font-family:'Poppins',sans-serif;font-size:.875rem;font-weight:600;color:#3A2E89;text-decoration:none;"
                >
                    <svg
                        width="16"
                        height="16"
                        fill="none"
                        stroke="#3A2E89"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                        ></path>
                    </svg>
                    Ver recursos de práctica
                </a>
            </div>
        </div>
    </section>

    <!-- ─── REGLAS DE LA COMPETENCIA ─────────────────────────── -->
    <section class="rg-section">
        <div class="rg-container">
            <h2
                style="font-family:'Poppins',sans-serif;font-size:2rem;font-weight:700;color:#3A2E89;text-align:center;margin:0 0 3.5rem;"
            >
                Reglas de la competencia
            </h2>

            <div class="rg-reglas-grid">
                {
                    [
                        {
                            icon: `<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>`,
                            title: "Composición",
                            desc: "3 estudiantes por equipo, misma institución",
                        },
                        {
                            icon: `<circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/>`,
                            title: "Plataforma",
                            desc: "OmegaUp — 1 usuario por equipo",
                        },
                        {
                            icon: `<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/>`,
                            title: "Conducta",
                            desc: "Cualquier intento de fraude resultará en descalificación inmediata.",
                        },
                        {
                            icon: `<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
                            title: "Lenguajes",
                            desc: "Python y C++ permitidos",
                        },
                        {
                            icon: `<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>`,
                            title: "Problemas",
                            desc: " 6 Problemas a resolver",
                        },
                        {
                            icon: `<rect width="20" height="14" x="2" y="5" rx="2"/><path d="M6 15V9l3 3.5L12 9v6"/><line x1="16" y1="9" x2="16" y2="15"/><path d="M13 13l3 3 3-3"/>`,
                            title: "Evaluación",
                            desc: "Por rapidez y cantidad de problemas",
                        },
                    ].map((r) => (
                        <div class="rg-rule-card">
                            <svg
                                class="rg-rule-icon"
                                aria-hidden="true"
                                width="32"
                                height="32"
                                fill="none"
                                stroke="#3A2E89"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                viewBox="0 0 24 24"
                                set:html={r.icon}
                            />
                            <p style="font-family:'Poppins',sans-serif;font-weight:600;color:#8078B5;margin:0 0 .25rem;">
                                {r.title}
                            </p>
                            <p style="font-family:'Inter',sans-serif;font-size:.875rem;color:rgba(1,1,1,.65);margin:0;">
                                {r.desc}
                            </p>
                        </div>
                    ))
                }
            </div>

            <div style="text-align:center;margin-top:3rem;">
                <a
                    href="/rules"
                    style="display:inline-flex;align-items:center;gap:.5rem;border:2px solid #3A2E89;border-radius:.5rem;padding:.75rem 1.75rem;font-family:'Poppins',sans-serif;font-size:.9375rem;font-weight:600;color:#3A2E89;text-decoration:none;"
                >
                    Ver reglamento completo
                    <svg
                        width="16"
                        height="16"
                        fill="none"
                        stroke="#3A2E89"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
                    </svg>
                </a>
            </div>
        </div>
    </section>

    <!-- ─── INSCRIPCIÓN ──────────────────────────────────────── -->
    <section class="rg-section">
        <div class="rg-container">
            <h2
                style="font-family:'Poppins',sans-serif;font-size:1.5rem;font-weight:700;color:#3A2E89;margin:0 0 .5rem;"
            >
                Inscripción de equipos
            </h2>
            <p
                style="font-family:'Inter',sans-serif;margin:0 0 1.5rem;font-size:.875rem;color:rgba(1,1,1,.6);"
            >
                Selecciona la categoría para continuar el registro.
            </p>
            <div class="rg-inscripcion-grid">
                <a
                    href="/inscripcion/registro?categoria=colegios"
                    class="rg-cat-card"
                >
                    <p
                        style="margin:0 0 .4rem;font-family:'Poppins',sans-serif;font-size:1.25rem;font-weight:600;color:#3A2E89;"
                    >
                        Colegios
                    </p>
                    <p
                        style="font-family:'Inter',sans-serif;margin:0;font-size:.875rem;color:rgba(1,1,1,.6);"
                    >
                        Para equipos de educación media.
                    </p>
                </a>
                <a
                    href="/inscripcion/registro?categoria=universidades"
                    class="rg-cat-card"
                >
                    <p
                        style="margin:0 0 .4rem;font-family:'Poppins',sans-serif;font-size:1.25rem;font-weight:600;color:#3A2E89;"
                    >
                        Universidades
                    </p>
                    <p
                        style="font-family:'Inter',sans-serif;margin:0;font-size:.875rem;color:rgba(1,1,1,.6);"
                    >
                        Para equipos de educación superior.
                    </p>
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* ── base ── */
    .rg-section {
        background: #fff;
        padding: 5rem 2rem;
        overflow: hidden;
        position: relative;
    }
    .rg-container {
        max-width: 960px;
        margin: 0 auto;
    }
    .rg-deco {
        position: absolute;
        font-family: "Poppins", sans-serif;
        font-weight: 700;
        font-size: 1.25rem;
        color: #455ce9;
        opacity: 0.35;
    }

    /* ── hero ── */
    .rg-hero-grid {
        display: grid;
        grid-template-columns: 2fr 3fr;
        align-items: center;
        gap: 3rem;
    }
    .rg-hero-title {
        font-family: "Poppins", sans-serif;
        font-size: 3rem;
        font-weight: 700;
        color: #3a2e89;
        line-height: 1.15;
        margin: 0;
    }
    .rg-hero-sub {
        margin-top: 1rem;
        font-family: "Inter", sans-serif;
        font-size: 0.875rem;
        color: rgba(1, 1, 1, 0.6);
        max-width: 22rem;
        line-height: 1.6;
    }

    /* ── proceso ── */
    .rg-proceso-grid {
        display: grid;
        grid-template-columns: 5fr 6fr;
        align-items: center;
        gap: 4rem;
        position: relative;
    }
    .rg-photos {
        position: relative;
        height: 450px;
    }
    .rg-badge-mobile {
        display: none;
    }
    .rg-steps {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }
    .rg-step {
        display: grid;
        grid-template-columns: 2rem minmax(0, 1fr);
        align-items: flex-start;
        gap: 1rem;
    }
    .rg-step-number {
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
        background: #3a2e89;
        color: #fff;
        font-family: "Poppins", sans-serif;
        font-weight: 700;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .rg-step-copy {
        min-width: 0;
    }
    .rg-step-title {
        margin: 0;
        font-family: "Poppins", sans-serif;
        font-weight: 600;
        color: #010101;
    }
    .rg-step-desc {
        margin: 0.1rem 0 0;
        font-family: "Inter", sans-serif;
        font-size: 0.875rem;
        color: rgba(1, 1, 1, 0.6);
    }

    /* ── reglas ── */
    .rg-reglas-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem 2rem;
    }
    .rg-rule-icon {
        display: block;
        margin-bottom: 0.5rem;
    }

    /* ── inscripcion ── */
    .rg-inscripcion-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    .rg-cat-card {
        display: block;
        border-radius: 0.5rem;
        border: 1px solid #eff4fe;
        background: #fff;
        padding: 1.5rem;
        text-decoration: none;
        box-shadow: 0 4px 20px rgba(58, 46, 137, 0.08);
        transition: box-shadow 0.2s;
    }
    .rg-cat-card:hover {
        box-shadow: 0 12px 40px rgba(58, 46, 137, 0.14);
    }

    /* ── tablet (≤ 768px) ── */
    @media (max-width: 768px) {
        .rg-section {
            padding: 3.5rem 1.25rem;
        }

        .rg-container {
            text-align: center;
        }

        .rg-hero-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .rg-hero-title {
            font-size: 2.25rem;
        }
        .rg-hero-sub {
            margin-left: auto;
            margin-right: auto;
        }

        .rg-proceso-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .rg-photos {
            display: none;
        }
        .rg-badge-mobile {
            display: flex;
            justify-content: center;
            margin-bottom: 1rem;
        }
        .rg-proceso-grid > div:last-child {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .rg-proceso-grid h2 {
            text-align: center !important;
        }
        .rg-steps {
            width: 100%;
            max-width: 24rem;
            margin-left: auto !important;
            margin-right: auto !important;
        }
        .rg-step {
            justify-content: stretch;
            text-align: left;
        }

        .rg-reglas-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem 1.5rem;
        }
        .rg-rule-card {
            max-width: 17rem;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
        }
        .rg-rule-icon {
            margin-left: auto;
            margin-right: auto;
        }
        .rg-inscripcion-grid {
            max-width: 34rem;
            margin-left: auto;
            margin-right: auto;
        }
        .rg-cat-card {
            text-align: center;
        }
    }

    /* ── mobile (≤ 480px) ── */
    @media (max-width: 480px) {
        .rg-section {
            padding: 2.5rem 1rem;
        }
        .rg-hero-title {
            font-size: 1.875rem;
        }

        .rg-reglas-grid {
            grid-template-columns: 1fr;
        }
        .rg-inscripcion-grid {
            grid-template-columns: 1fr;
            max-width: 22rem;
        }
    }
</style>
