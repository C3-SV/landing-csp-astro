---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pageMetadata } from "../../lib/site";
import { RegistrationRoute } from "../../components/RegistrationRoute";
import UploadThingSSR from "../../components/UploadThingSSR.astro";

export const prerender = true;
---

<BaseLayout
  title={pageMetadata.registrationForm.title}
  description={pageMetadata.registrationForm.description}
  canonical={pageMetadata.registrationForm.canonical}
  noindex={pageMetadata.registrationForm.noindex}
>
  <UploadThingSSR />
  <div class="flex flex-1 flex-col">
    <main class="mx-auto w-full max-w-4xl flex-1 px-4 py-10">
      <h1 class="mb-2 font-display text-3xl font-semibold text-csp-primary">Formulario de inscripción</h1>
      <p class="mb-6 text-sm text-csp-black/70">Completa los 4 pasos para registrar oficialmente al equipo.</p>

      <RegistrationRoute client:load />
    </main>
  </div>
</BaseLayout>
