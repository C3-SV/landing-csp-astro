---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { EVENT_NAME } from "../../lib/constants";
import Card from "../../components/Card.astro";

export const prerender = false;

const id = Astro.url.searchParams.get("id")?.trim() ?? "";
const emailStatus = Astro.url.searchParams.get("emailStatus")?.trim() ?? "";
const isEmailSent = emailStatus === "sent";
const isEmailWarning = emailStatus === "warning";

const confirmationMessage = isEmailSent
  ? "¡Inscripción recibida! Enviamos un correo de confirmación al capitán del equipo."
  : "Tu inscripción fue recibida correctamente. Si no recibís el correo de confirmación en unos minutos, revisá spam o contactanos.";
---

<BaseLayout title={`Inscripción enviada | ${EVENT_NAME}`} description="Confirmación de inscripción enviada correctamente.">
  <div class="flex flex-1 flex-col">
    <main class="mx-auto flex w-full max-w-4xl flex-1 items-center px-4 py-12">
      <Card class="w-full text-center">
        <h1 class="font-display text-3xl font-semibold text-csp-primary">Inscripción enviada</h1>
        <p class="mt-3 text-csp-black/70">
          {confirmationMessage}
        </p>
        {isEmailWarning ? (
          <p class="mt-2 text-sm text-csp-black/60">
            Tu registro ya fue guardado exitosamente y está en revisión.
          </p>
        ) : null}

        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a
            class="inline-flex h-11 items-center justify-center rounded-md bg-csp-blue px-5 text-sm font-semibold text-csp-white hover:bg-csp-primary"
            href="/inscripcion"
          >
            Nueva inscripción
          </a>
          <a
            class="inline-flex h-11 items-center justify-center rounded-md border border-csp-primary px-5 text-sm font-semibold text-csp-primary hover:bg-csp-soft"
            href="/"
          >
            Volver al inicio
          </a>
        </div>
      </Card>
    </main>
  </div>
</BaseLayout>
