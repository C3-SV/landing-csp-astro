---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageMetadata } from "../lib/site";

export const prerender = true;
---

<BaseLayout
    title={pageMetadata.phases.title}
    description={pageMetadata.phases.description}
    canonical={pageMetadata.phases.canonical}
    noindex={pageMetadata.phases.noindex}
>
    <main class="flex-1">
        <h1 class="sr-only">Fases de la Copa Salvadoreña de Programación 2026</h1>
    </main>
</BaseLayout>
