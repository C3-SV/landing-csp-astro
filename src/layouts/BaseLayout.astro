---
import { EVENT_NAME } from "../lib/constants";
import Footer from "../components/Footer.astro";
import PublicHeader from "../components/PublicHeader.astro";
import "../styles/global.css";

type Props = {
    title?: string;
    description?: string;
};

const {
    title = EVENT_NAME,
    description = "Módulo de inscripción y administración de la CSP 2026.",
} = Astro.props as Props;
---

<!doctype html>
<html lang="es" class="h-full antialiased">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
        <link rel="shortcut icon" href="/favicon.svg?v=2" />
        <title>{title}</title>
    </head>
    <body class="min-h-full flex flex-col bg-csp-background text-csp-black">
        <PublicHeader />
        <slot />
        <Footer />
    </body>
</html>
