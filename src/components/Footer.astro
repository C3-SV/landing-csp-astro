---
import { EVENT_NAME } from "../lib/constants";

const links = [
    { label: "Inicio", href: "/" },
    { label: "Reglamento", href: "/rules" },
];

const email = "competitivecodingclub.sv@gmail.com";
const instagramUrl =
    "https://www.instagram.com/c3.elsalvador?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==";
const instagramHandle = "@c3.elsalvador";
---

<footer class="bg-[#0F203E] text-csp-white">
    <div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
        <div
            class="grid gap-10 text-center justify-items-center lg:grid-cols-[auto_auto_auto_minmax(16rem,20rem)] lg:items-start lg:justify-items-start lg:gap-12 lg:text-left"
        >
            <div class="flex justify-center lg:justify-self-start">
                <img
                    alt="Logo C3"
                    class="h-20 w-auto"
                    loading="lazy"
                    src="/brands/c3-blanco-no-fondo.png"
                />
            </div>

            <div class="min-w-0 lg:justify-self-start">
                    <h3 class="text-2xl font-semibold text-[#14B8A6]">
                        Enlaces
                    </h3>
                    <nav aria-label="Enlaces del footer" class="mt-4">
                        <ul class="flex flex-col gap-3 text-sm font-semibold">
                            {
                                links.map((link) => (
                                    <li>
                                        <a
                                            class="text-csp-white/85 no-underline hover:text-[#cdf5f2ca] focus-visible:text-[#cdf5f2ca]"
                                            href={link.href}
                                        >
                                            {link.label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </nav>
            </div>

            <div class="min-w-0 lg:justify-self-start">
                    <h3 class="text-2xl font-semibold text-[#14B8A6]">
                        ¡Contáctanos!
                    </h3>
                    <div class="mt-4 text-sm font-semibold">
                        <a
                            class="break-words text-csp-white/85 no-underline hover:text-[#cdf5f2ca] focus-visible:text-[#cdf5f2ca]"
                            href={`mailto:${email}`}
                        >
                            {email}
                        </a>
                    </div>
            </div>

            <div
                class="flex w-full max-w-70 min-w-0 flex-col items-center justify-self-center gap-8 text-center lg:max-w-none lg:items-start lg:justify-self-stretch lg:!text-left"
            >
                <p
                    class="w-full break-words font-display text-center text-2xl font-semibold leading-7 lg:!text-left lg:text-3xl lg:leading-8"
                >
                    Tu próximo gran algoritmo comienza aquí
                </p>
                <a
                    class="inline-flex items-center gap-3 text-sm font-semibold text-csp-white no-underline hover:text-[#cdf5f2ca] focus-visible:text-[#cdf5f2ca] lg:self-start"
                    href={instagramUrl}
                    rel="noreferrer"
                    target="_blank"
                >
                    <svg
                        aria-hidden="true"
                        class="h-6 w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                    >
                        <rect
                            x="3"
                            y="3"
                            width="18"
                            height="18"
                            rx="5"
                            stroke="currentColor"
                            stroke-width="2"></rect>
                        <circle
                            cx="12"
                            cy="12"
                            r="4"
                            stroke="currentColor"
                            stroke-width="2"></circle>
                        <circle cx="17" cy="7" r="1.5" fill="currentColor"
                        ></circle>
                    </svg>
                    {instagramHandle}
                </a>
            </div>
        </div>

        <div
            class="mt-12 border-t border-csp-white/15 pt-6 text-center text-xs text-csp-white/70"
        >
            {EVENT_NAME} | Competitive Coding Club
        </div>
    </div>
</footer>
