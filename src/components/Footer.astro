---
import { EVENT_NAME } from "../lib/constants";

const links = [
	{ label: "Inicio", href: "/" },
	{ label: "Fases", href: "/phases" },
	{ label: "Reglamento", href: "/rules" },
];

const email = "competitivecodingclub.sv@gmail.com";
const instagramUrl =
	"https://www.instagram.com/c3.elsalvador?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==";
const instagramHandle = "@c3.elsalvador";
---

<footer class="bg-[#0F203E] text-csp-white">
	<div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
		<div class="grid gap-12 text-center justify-items-center lg:grid-cols-[auto_minmax(0,1fr)_auto] lg:items-start">
			<div class="flex justify-center lg:justify-start">
				<img
					alt="Logo C3"
					class="h-20 w-auto"
					loading="lazy"
					src="/brands/c3-blanco-no-fondo.png"
				/>
			</div>

			<div class="grid gap-10 sm:grid-cols-2 sm:gap-12">
				<div>
					<h3 class="text-2xl font-semibold text-[#14B8A6]">Enlaces</h3>
					<nav aria-label="Enlaces del footer" class="mt-4">
						<ul class="flex flex-col gap-3 text-sm font-semibold">
							{links.map((link) => (
								<li>
									<a class="footer-link footer-link-teal" href={link.href}>
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</nav>
				</div>

				<div>
					<h3 class="text-2xl font-semibold text-[#14B8A6]">¡Contáctanos!</h3>
					<div class="mt-4 text-sm font-semibold">
						<a class="footer-link footer-link-teal" href={`mailto:${email}`}>
							{email}
						</a>
					</div>
				</div>
			</div>

			<div class="flex flex-col items-center gap-10 text-right lg:items-end lg:text-right lg:justify-self-end">
				<p class="footer-hero">Tu próximo gran algoritmo comienza aquí</p>
				<a
					class="footer-link inline-flex items-center gap-3 text-sm font-semibold"
					href={instagramUrl}
					rel="noreferrer"
					target="_blank"
				>
					<svg
						aria-hidden="true"
						class="h-6 w-6"
						fill="none"
						viewBox="0 0 24 24"
					>
						<rect
							x="3"
							y="3"
							width="18"
							height="18"
							rx="5"
							stroke="currentColor"
							stroke-width="2"
						/>
						<circle
							cx="12"
							cy="12"
							r="4"
							stroke="currentColor"
							stroke-width="2"
						/>
						<circle cx="17" cy="7" r="1.5" fill="currentColor" />
					</svg>
					{instagramHandle}
				</a>
			</div>
		</div>

		<div class="mt-12 border-t border-csp-white/15 pt-6 text-center text-xs text-csp-white/70">
			{EVENT_NAME} | Competitive Coding Club
		</div>
	</div>
</footer>

<style>
	.footer-hero {
		max-width: 22rem;
		font-family: var(--font-display), system-ui, sans-serif;
		font-size: clamp(1.5rem, 2.3vw, 2.2rem);
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.2;
	}

	.footer-link {
		color: inherit;
		text-decoration: none;
	}

	.footer-link-teal {
        color: rgba(255, 255, 255, 0.85);
	}

	.footer-link:hover,
	.footer-link:focus-visible {
		color: #cdf5f2ca;
	}

</style>
