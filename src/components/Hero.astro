---
import "../styles/global.css";
---

<section class="w-full bg-csp-background py-12 sm:py-16 lg:py-20">
    <div
        class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:gap-12 lg:px-8"
    >
        <div class="max-w-xl">
            <h1
                class="font-display text-4xl font-black leading-tight text-csp-primary sm:text-5xl lg:text-6xl"
            >
                Copa Salvadoreña de Programación
            </h1>
            <p
                class="mt-5 max-w-lg text-sm leading-6 text-csp-black/60 sm:text-base"
            >
                La competencia nacional que reúne el talento de colegios y
                universidades para resolver problemas, fortalecer su pensamiento
                algorítmico y conectar con una comunidad técnica de alto nivel.
            </p>
        </div>

        <div class="flex justify-center lg:justify-end">
            <img
                src="/index/fotoHero.webp"
                alt="Participantes de la Copa Salvadoreña de Programación"
                class="h-64 w-full max-w-lg rounded-2xl object-cover shadow-csp-lg sm:h-80 lg:h-96 lg:max-w-xl"
            />
        </div>
    </div>
</section>
